{
    "name": "travel-blogs",
    "version": "1.0.0",
    "description": "Users should be able to post their travel diaries",
    "license": "ISC",
    "author": "Geneka",
    "type": "module",
    "main": "dist/app.js",
    "imports": {
        "#middlewares/*": "./src/middlewares/*",
        "#routes/*": "./src/routes/*",
        "#validations/*": "./src/validations/*",
        "#services/*": "./src/services/*",
        "#controllers/*": "./src/controllers/*",
        "#db": "./src/config/db",
        "#utils/*": "./src/utils/*",
        "#generated/*": "./generated/*"
    },
    "scripts": {
        "build": "tsc && tsc-alias",
        "start": "node --env-file=.env dist/app.js",
        "dev": "tsx watch --env-file=.env app.ts",
        "db:sync": "prisma db pull && prisma generate",
        "sql": "prisma migrate diff  --from-empty  --to-schema prisma/schema.prisma --script > prisma/migrations/migration.sql"
    },
    "dependencies": {
        "@prisma/adapter-mariadb": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.0.2",
        "razorpay": "^2.9.6",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.3.2",
        "globals": "^17.3.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "prisma": "^7.3.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
